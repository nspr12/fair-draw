<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.fair.draw.mapper.EventMapper">

    <!-- 변경: 새 컬럼 추가 -->
    <resultMap id="eventMap" type="com.fair.draw.domain.Event">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="thumbnailUrl" column="thumbnail_url"/>
        <result property="startDate" column="start_date"/>
        <result property="endDate" column="end_date"/>
        <result property="drawDate" column="draw_date"/>
        <result property="announceStartDate" column="announce_start_date"/>
        <result property="announceEndDate" column="announce_end_date"/>
        <result property="maxParticipants" column="max_participants"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="eventMap">
        SELECT * FROM event WHERE id = #{id}
    </select>

    <select id="findActiveEvent" resultMap="eventMap">
        SELECT * FROM event
        WHERE status = #{status}
          AND start_date &lt;= CURDATE()
          AND end_date &gt;= CURDATE()
        LIMIT 1
    </select>

    <update id="updateStatus">
        UPDATE event SET status = #{status} WHERE id = #{id}
    </update>

</mapper>