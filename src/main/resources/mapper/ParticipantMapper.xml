<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lotto.event.mapper.ParticipantMapper">

    <resultMap id="participantMap" type="com.lotto.event.domain.Participant">
        <id property="id" column="id"/>
        <result property="eventId" column="event_id"/>
        <result property="participantNo" column="participant_no"/>
        <result property="phoneNumber" column="phone_number"/>
        <result property="isVerified" column="is_verified"/>
        <result property="checkCount" column="check_count"/>
        <result property="lastCheckedAt" column="last_checked_at"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO participant (event_id, participant_no, phone_number, is_verified)
        VALUES (#{eventId}, #{participantNo}, #{phoneNumber}, #{isVerified})
    </insert>

    <select id="findById" resultMap="participantMap">
        SELECT * FROM participant WHERE id = #{id}
    </select>

    <select id="findByEventAndPhone" resultMap="participantMap">
        SELECT * FROM participant
        WHERE event_id = #{eventId} AND phone_number = #{phoneNumber}
    </select>

    <select id="getMaxParticipantNo" resultType="int">
        SELECT IFNULL(MAX(participant_no), 0) FROM participant WHERE event_id = #{eventId}
    </select>

    <select id="countByEvent" resultType="int">
        SELECT COUNT(*) FROM participant WHERE event_id = #{eventId}
    </select>

    <select id="findAllByEvent" resultMap="participantMap">
        SELECT * FROM participant WHERE event_id = #{eventId}
    </select>

    <select id="findUncheckedWinners" resultMap="participantMap">
        SELECT p.* FROM participant p
                            INNER JOIN winner_result wr ON p.id = wr.participant_id
        WHERE p.event_id = #{eventId} AND p.check_count = 0
    </select>

    <update id="incrementCheckCount">
        UPDATE participant
        SET check_count = check_count + 1, last_checked_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>