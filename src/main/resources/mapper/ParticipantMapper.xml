<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.fair.draw.mapper.ParticipantMapper">

    <resultMap id="participantMap" type="com.fair.draw.domain.Participant">
        <id property="id" column="id"/>
        <result property="eventId" column="event_id"/>
        <result property="phoneNumber" column="phone_number"/>
        <result property="isVerified" column="is_verified"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO participant (event_id, phone_number, is_verified)
        VALUES (#{eventId}, #{phoneNumber}, #{isVerified})
    </insert>

    <select id="findById" resultMap="participantMap">
        SELECT * FROM participant WHERE id = #{id}
    </select>

    <select id="findByEventAndPhone" resultMap="participantMap">
        SELECT * FROM participant
        WHERE event_id = #{eventId} AND phone_number = #{phoneNumber}
    </select>

    <select id="countByEvent" resultType="int">
        SELECT COUNT(*) FROM participant WHERE event_id = #{eventId}
    </select>

    <select id="countByEventForUpdate" resultType="int">
        SELECT COUNT(*) FROM participant WHERE event_id = #{eventId} FOR UPDATE
    </select>

    <select id="findRandomWinnerIds" resultType="java.lang.Long">
        SELECT id FROM participant
        WHERE event_id = #{eventId}
        ORDER BY RAND()
        LIMIT #{limit}
    </select>

    <delete id="deleteByEvent">
        DELETE FROM participant WHERE event_id = #{eventId}
    </delete>

</mapper>