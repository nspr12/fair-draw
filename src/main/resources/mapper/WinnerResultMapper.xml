<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.fair.draw.mapper.WinnerResultMapper">

    <resultMap id="winnerResultMap" type="com.fair.draw.domain.WinnerResult">
        <id property="id" column="id"/>
        <result property="participantId" column="participant_id"/>
        <result property="rankType" column="rank_type"/>
        <result property="matchedCount" column="matched_count"/>
        <result property="prizeStatus" column="prize_status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO winner_result (participant_id, rank_type, matched_count, prize_status)
        VALUES (#{participantId}, #{rankType}, #{matchedCount}, #{prizeStatus})
    </insert>

    <select id="findByParticipant" resultMap="winnerResultMap">
        SELECT * FROM winner_result WHERE participant_id = #{participantId}
    </select>

    <select id="findByRank" resultMap="winnerResultMap">
        SELECT * FROM winner_result WHERE rank_type = #{rankType}
    </select>

    <select id="countByRank" resultType="java.util.HashMap">
        SELECT rank_type as rankType, COUNT(*) as cnt
        FROM winner_result wr
                 JOIN participant p ON wr.participant_id = p.id
        WHERE p.event_id = #{eventId}
        GROUP BY rank_type
        ORDER BY rank_type
    </select>

    <delete id="deleteByEvent">
        DELETE FROM winner_result WHERE participant_id IN
                                        (SELECT id FROM participant WHERE event_id = #{eventId})
    </delete>
</mapper>