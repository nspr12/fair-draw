<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lotto.event.mapper.WinningNumberMapper">

    <resultMap id="winningNumberMap" type="com.lotto.event.domain.WinningNumber">
        <id property="id" column="id"/>
        <result property="eventId" column="event_id"/>
        <result property="number" column="number"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO winning_number (event_id, number)
        VALUES (#{eventId}, #{number})
    </insert>

    <select id="findByEvent" resultMap="winningNumberMap">
        SELECT * FROM winning_number WHERE event_id = #{eventId} ORDER BY number ASC
    </select>

</mapper>